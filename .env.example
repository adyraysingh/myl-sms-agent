# MakeYourLabel AI SMS Agent - Environment Variables
# Using CallHippo for SMS

# ==========================================
# SERVER
# ==========================================
PORT=3000
NODE_ENV=production

# ==========================================
# CALLHIPPO SMS
# ==========================================
CALLHIPPO_API_KEY=your_callhippo_auth_token_here
CALLHIPPO_VIRTUAL_NUMBER=+16506685023

# ==========================================
# OPENAI
# ==========================================
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# ==========================================
# DATABASE (Supabase PostgreSQL)
# ==========================================
DATABASE_URL=postgresql://postgres.yrezwfmjmrlviyzlqrkp:[YOUR-PASSWORD]@aws-1-ap-south-1.pooler.supabase.com:5432/postgres

# ==========================================
# ZOHO CRM
# ==========================================
ZOHO_CLIENT_ID=your_zoho_client_id
ZOHO_CLIENT_SECRET=your_zoho_client_secret
ZOHO_REFRESH_TOKEN=your_zoho_refresh_token
ZOHO_REDIRECT_URI=https://www.zoho.com/crm/developer/docs/api/v2/

# ==========================================
# BUSINESS CONFIG
# ==========================================
BUSINESS_NAME=MakeYourLabel
